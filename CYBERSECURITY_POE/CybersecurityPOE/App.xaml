<Application x:Class="CybersecurityPOE.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ═══════════════════════════════════════════════════════
             TERMINAL GREEN  •  Colour palette
             Original: deep navy + cyan
             New:      pure black + green phosphor terminal
        ════════════════════════════════════════════════════════════ -->
        <Color x:Key="TermBlack">#000000</Color>
        <Color x:Key="TermDark">#060606</Color>
        <Color x:Key="TermPanel">#0A0F0A</Color>
        <Color x:Key="TermCard">#0F180F</Color>
        <Color x:Key="TermBorder">#1A3A1A</Color>
        <Color x:Key="GreenBright">#00FF41</Color>
        <Color x:Key="GreenMid">#00CC33</Color>
        <Color x:Key="GreenDim">#007A1F</Color>
        <Color x:Key="GreenFaint">#003D0F</Color>
        <Color x:Key="AmberAccent">#FFB300</Color>
        <Color x:Key="RedAlert">#FF2222</Color>
        <Color x:Key="WhiteText">#E8FFE8</Color>
        <Color x:Key="GrayGreen">#4A6A4A</Color>

        <SolidColorBrush x:Key="TermBlackBrush"   Color="{StaticResource TermBlack}"/>
        <SolidColorBrush x:Key="TermDarkBrush"    Color="{StaticResource TermDark}"/>
        <SolidColorBrush x:Key="TermPanelBrush"   Color="{StaticResource TermPanel}"/>
        <SolidColorBrush x:Key="TermCardBrush"    Color="{StaticResource TermCard}"/>
        <SolidColorBrush x:Key="TermBorderBrush"  Color="{StaticResource TermBorder}"/>
        <SolidColorBrush x:Key="GreenBrightBrush" Color="{StaticResource GreenBright}"/>
        <SolidColorBrush x:Key="GreenMidBrush"    Color="{StaticResource GreenMid}"/>
        <SolidColorBrush x:Key="GreenDimBrush"    Color="{StaticResource GreenDim}"/>
        <SolidColorBrush x:Key="AmberBrush"       Color="{StaticResource AmberAccent}"/>
        <SolidColorBrush x:Key="RedAlertBrush"    Color="{StaticResource RedAlert}"/>
        <SolidColorBrush x:Key="WhiteTextBrush"   Color="{StaticResource WhiteText}"/>
        <SolidColorBrush x:Key="GrayGreenBrush"   Color="{StaticResource GrayGreen}"/>

        <!-- Scrollbar: slim green -->
        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#1A5A1A" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Terminal green button -->
        <Style x:Key="TermButton" TargetType="Button">
            <Setter Property="Background" Value="#0A1F0A"/>
            <Setter Property="Foreground" Value="{StaticResource GreenBrightBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenMidBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#003A00"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource GreenBrightBrush}"/>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF41" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#005500"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Amber action button (send / confirm) -->
        <Style x:Key="AmberButton" TargetType="Button">
            <Setter Property="Background" Value="#2A1A00"/>
            <Setter Property="Foreground" Value="{StaticResource AmberBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AmberBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#3A2500"/>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFB300" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#4A3000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Topic pill button -->
        <Style x:Key="TopicPill" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource GreenMidBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenDimBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#0A200A"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource GreenBrightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource GreenBrightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#003A00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Terminal input box -->
        <Style x:Key="TermInput" TargetType="TextBox">
            <Setter Property="Background" Value="#050A05"/>
            <Setter Property="Foreground" Value="{StaticResource GreenBrightBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenBrightBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenDimBrush}"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="SelectionBrush" Value="{StaticResource GreenDimBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenBrightBrush}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF41" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
