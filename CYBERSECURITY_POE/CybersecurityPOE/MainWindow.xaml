<Window x:Class="CybersecurityPOE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity POE — Terminal v2.0"
        Height="860" Width="1300"
        MinHeight="640" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource TermBlackBrush}"
        FontFamily="Consolas"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <DropShadowEffect x:Key="GreenGlow"  Color="#00FF41" BlurRadius="16" ShadowDepth="0" Opacity="0.7"/>
        <DropShadowEffect x:Key="GreenGlowS" Color="#00FF41" BlurRadius="6"  ShadowDepth="0" Opacity="0.4"/>
        <DropShadowEffect x:Key="AmberGlow"  Color="#FFB300" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header bar -->
            <RowDefinition Height="56"/>
            <!-- Main body -->
            <RowDefinition Height="*"/>
            <!-- Input area -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             ROW 0  — HEADER BAR
        ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#050A05">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1A3A1A"/>
            </Border.BorderBrush>
            <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="[ " FontSize="18" Foreground="{StaticResource GreenDimBrush}"/>
                    <TextBlock Text="CYBER" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrightBrush}"
                               Effect="{StaticResource GreenGlow}"/>
                    <TextBlock Text=" POE" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource WhiteTextBrush}"/>
                    <TextBlock Text=" ]" FontSize="18" Foreground="{StaticResource GreenDimBrush}"/>
                    <Border Background="#0A200A" BorderBrush="{StaticResource GreenDimBrush}"
                            BorderThickness="1" CornerRadius="2" Padding="6,2" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="TERMINAL" FontSize="10" Foreground="{StaticResource GreenMidBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Centre subtitle -->
                <TextBlock Grid.Column="1"
                           Text="// Cybersecurity POE  ·  Awareness Bot  ·  Keyword Recognition  ·  Memory &amp; Sentiment Engine"
                           FontSize="11" Foreground="{StaticResource GrayGreenBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Clock -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" HorizontalAlignment="Right">
                    <TextBlock x:Name="ClockLabel" Text="00:00:00"
                               FontSize="14" FontFamily="Consolas" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrightBrush}"
                               Effect="{StaticResource GreenGlowS}"/>
                    <TextBlock x:Name="UserStatusLabel" Text="NO SESSION"
                               FontSize="10" Foreground="{StaticResource GrayGreenBrush}"
                               HorizontalAlignment="Right"/>
                </StackPanel>

                <!-- Online indicator -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrightBrush}" Margin="0,0,5,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FF41" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="ONLINE" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrightBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 1  — MAIN BODY  (sidebar | chat | info panel)
        ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left sidebar: topics + actions -->
                <ColumnDefinition Width="220"/>
                <!-- Chat area -->
                <ColumnDefinition Width="*"/>
                <!-- Right panel: memory + stats -->
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT SIDEBAR ─────────────────────────────── -->
            <Border Grid.Column="0" Background="{StaticResource TermPanelBrush}">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#1A3A1A"/>
                </Border.BorderBrush>
                <Border.BorderThickness>0,0,1,0</Border.BorderThickness>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,14,12,14">

                        <!-- Section: Topics -->
                        <TextBlock Text="> TOPICS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrightBrush}"
                                   Margin="0,0,0,8"/>

                        <Button Content="🎣  Phishing"             Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="phishing"/>
                        <Button Content="🔑  Password Safety"      Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="password safety"/>
                        <Button Content="🛡  Two-Factor Auth"      Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="two-factor authentication"/>
                        <Button Content="💀  Ransomware"           Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="ransomware"/>
                        <Button Content="🎭  Social Engineering"   Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="social engineering"/>
                        <Button Content="🌐  Safe Browsing"        Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="safe browsing"/>
                        <Button Content="🦠  Malware"              Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="malware"/>
                        <Button Content="🧹  Cyber Hygiene"        Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="cyber hygiene"/>
                        <Button Content="⚠  Scams"                Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="scams"/>
                        <Button Content="🔒  Privacy"              Style="{StaticResource TopicPill}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="TopicButton_Click" Tag="privacy"/>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource TermBorderBrush}" Margin="0,14,0,14"/>

                        <!-- Section: Actions -->
                        <TextBlock Text="> ACTIONS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AmberBrush}"
                                   Margin="0,0,0,8"/>

                        <Button Content="▶  Start Quiz"        Style="{StaticResource TermButton}" HorizontalAlignment="Stretch" Margin="0,3" Click="BtnStartQuiz_Click"/>
                        <Button Content="📋  View Tasks"        Style="{StaticResource TermButton}" HorizontalAlignment="Stretch" Margin="0,3" Click="BtnShowTasks_Click"/>
                        <Button Content="➕  Add Task"          Style="{StaticResource TermButton}" HorizontalAlignment="Stretch" Margin="0,3" Click="BtnAddTask_Click"/>
                        <Button Content="📜  Activity Log"      Style="{StaticResource TermButton}" HorizontalAlignment="Stretch" Margin="0,3" Click="BtnActivityLog_Click"/>
                        <Button Content="🔄  Reset Session"     Style="{StaticResource TermButton}" HorizontalAlignment="Stretch" Margin="0,3" Click="BtnReset_Click"/>
                        <Button Content="🔊  Toggle Voice"      Style="{StaticResource TermButton}" HorizontalAlignment="Stretch" Margin="0,3" Click="BtnSpeech_Click"/>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource TermBorderBrush}" Margin="0,14,0,14"/>

                        <!-- Section: Quick Task -->
                        <TextBlock Text="> QUICK TASK" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource GreenMidBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="QuickTaskName"
                                 Text="Task name..."
                                 Style="{StaticResource TermInput}"
                                 FontSize="11"
                                 Margin="0,0,0,5"
                                 GotFocus="QuickTaskName_GotFocus"
                                 LostFocus="QuickTaskName_LostFocus"/>
                        <DatePicker x:Name="QuickTaskDate"
                                    FontFamily="Consolas" FontSize="11"
                                    Background="#050A05" Foreground="{StaticResource GreenBrightBrush}"
                                    BorderBrush="{StaticResource GreenDimBrush}"
                                    Margin="0,0,0,5"/>
                        <Button Content="⚡  Set Reminder"
                                Style="{StaticResource TermButton}"
                                HorizontalAlignment="Stretch"
                                Click="BtnQuickAddTask_Click"/>
                        <TextBlock x:Name="TaskStatusLabel"
                                   Text="● In-memory mode"
                                   FontSize="10" Foreground="{StaticResource GreenDimBrush}"
                                   Margin="0,5,0,0"/>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource TermBorderBrush}" Margin="0,14,0,14"/>

                        <!-- Detected keywords -->
                        <TextBlock Text="> KEYWORDS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource GrayGreenBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="NoKeywordsLabel"
                                   Text="none detected yet"
                                   FontSize="10" Foreground="{StaticResource GrayGreenBrush}"
                                   FontStyle="Italic"/>
                        <ItemsControl x:Name="KeywordsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0A1A0A" BorderBrush="{StaticResource GreenDimBrush}"
                                            BorderThickness="1" CornerRadius="2" Padding="6,3" Margin="0,2">
                                        <TextBlock Text="{Binding}" FontSize="10"
                                                   Foreground="{StaticResource GreenBrightBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── CHAT AREA ─────────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- ASCII banner -->
                    <RowDefinition Height="Auto"/>
                    <!-- Chat messages -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ASCII splash header inside chat -->
                <Border Grid.Row="0" Background="#030803" Padding="0,10,0,6">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#0F2A0F"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
                    <TextBlock TextAlignment="Center"
                               FontSize="9" FontFamily="Consolas"
                               Foreground="{StaticResource GreenDimBrush}">
<![CDATA[  ██████╗ ██████╗  █████╗  ██████╗███████╗     █████╗ ██╗
 ██╔════╝ ██╔══██╗██╔══██╗██╔════╝██╔════╝    ██╔══██╗██║
 ██║  ███╗██████╔╝███████║██║     █████╗      ███████║██║
 ██║   ██║██╔══██╗██╔══██║██║     ██╔══╝      ██╔══██║██║
 ╚██████╔╝██║  ██║██║  ██║╚██████╗███████╗    ██║  ██║██║
  ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚══════╝    ╚═╝  ╚═╝╚═╝
         [ Cybersecurity POE  //  Awareness Terminal  //  v2.0 ]]]>
                    </TextBlock>
                </Border>

                <!-- Scrollable chat messages -->
                <ScrollViewer x:Name="ChatScrollViewer"
                              Grid.Row="1"
                              Background="#040904"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,10">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel x:Name="ChatPanel"/>
                </ScrollViewer>
            </Grid>

            <!-- ── RIGHT INFO PANEL ──────────────────────────── -->
            <Border Grid.Column="2" Background="{StaticResource TermPanelBrush}">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#1A3A1A"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1,0,0,0</Border.BorderThickness>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,14,12,14">

                        <!-- Memory card -->
                        <Border Background="#080F08" BorderBrush="{StaticResource GreenDimBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="> MEMORY.SYS" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource GreenBrightBrush}"
                                           Margin="0,0,0,10"
                                           Effect="{StaticResource GreenGlowS}"/>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="USER:" FontSize="10" Foreground="{StaticResource GrayGreenBrush}"/>
                                    <TextBlock x:Name="MemUserName" Grid.Column="1"
                                               Text="—" FontSize="10"
                                               Foreground="{StaticResource GreenBrightBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MOOD:" FontSize="10" Foreground="{StaticResource GrayGreenBrush}"/>
                                    <TextBlock x:Name="MemMood" Grid.Column="1"
                                               Text="—" FontSize="10"
                                               Foreground="{StaticResource GreenBrightBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="TOPIC:" FontSize="10" Foreground="{StaticResource GrayGreenBrush}"/>
                                    <TextBlock x:Name="MemTopic" Grid.Column="1"
                                               Text="—" FontSize="10"
                                               Foreground="{StaticResource GreenBrightBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MSGS:" FontSize="10" Foreground="{StaticResource GrayGreenBrush}"/>
                                    <TextBlock x:Name="MemMessages" Grid.Column="1"
                                               Text="0" FontSize="10"
                                               Foreground="{StaticResource GreenBrightBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Awareness meter -->
                        <Border Background="#080F08" BorderBrush="{StaticResource GreenDimBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="> AWARENESS.EXE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource GreenMidBrush}" Margin="0,0,0,8"/>
                                <ProgressBar x:Name="AwarenessBar" Value="0" Maximum="100"
                                             Height="10" Background="#0A1A0A" Margin="0,0,0,6">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#004400" Offset="0"/>
                                            <GradientStop Color="#00FF41" Offset="1"/>
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <Border x:Name="PART_Track" CornerRadius="2">
                                                    <Border x:Name="PART_Indicator"
                                                            Background="{TemplateBinding Foreground}"
                                                            HorizontalAlignment="Left"
                                                            CornerRadius="2"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                                <TextBlock x:Name="AwarenessLabel" Text="0% — INIT"
                                           FontSize="10" Foreground="{StaticResource GrayGreenBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Quiz score -->
                        <Border Background="#080F08" BorderBrush="{StaticResource AmberBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="> QUIZ.LOG" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AmberBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="QuizScoreLabel"
                                           Text="No quiz taken yet."
                                           FontSize="10" Foreground="{StaticResource GrayGreenBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <Button Content="▶  Run Quiz"
                                        Style="{StaticResource TermButton}"
                                        HorizontalAlignment="Stretch"
                                        Click="BtnStartQuiz_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Security tip -->
                        <Border Background="#080F08" BorderBrush="{StaticResource GreenDimBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="> TIP.TXT" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource GreenMidBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="SecurityTipLabel"
                                           Text="Use a password manager to generate and store unique, strong passwords."
                                           FontSize="10" Foreground="{StaticResource WhiteTextBrush}"
                                           TextWrapping="Wrap" LineHeight="16"/>
                            </StackPanel>
                        </Border>

                        <!-- Topics explored list -->
                        <Border Background="#080F08" BorderBrush="{StaticResource GreenDimBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12">
                            <StackPanel>
                                <TextBlock Text="> TOPICS.EXPLORED" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource GrayGreenBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="NoTopicsLabel"
                                           Text="none yet"
                                           FontSize="10" Foreground="{StaticResource GrayGreenBrush}"
                                           FontStyle="Italic"/>
                                <ItemsControl x:Name="TopicsExploredList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10"
                                                       Foreground="{StaticResource GreenMidBrush}"
                                                       Margin="0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             ROW 2  — INPUT AREA
        ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#050A05" Padding="14,10">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1A3A1A"/>
            </Border.BorderBrush>
            <Border.BorderThickness>0,1,0,0</Border.BorderThickness>
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Prompt label -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Text input -->
                    <ColumnDefinition Width="*"/>
                    <!-- Send button -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Clear button -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Blinking prompt -->
                <TextBlock Grid.Column="0"
                           Text="root@grace:~$ "
                           FontSize="14" FontFamily="Consolas" FontWeight="Bold"
                           Foreground="{StaticResource GreenBrightBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Effect="{StaticResource GreenGlowS}"/>

                <!-- Input box -->
                <TextBox x:Name="InputBox"
                         Grid.Column="1"
                         Style="{StaticResource TermInput}"
                         VerticalAlignment="Center"
                         KeyDown="InputBox_KeyDown"/>

                <!-- SEND -->
                <Button x:Name="SendBtn"
                        Grid.Column="2"
                        Content="SEND ▶"
                        Style="{StaticResource AmberButton}"
                        Margin="10,0,6,0"
                        VerticalAlignment="Center"
                        Click="SendBtn_Click"/>

                <!-- CLEAR -->
                <Button Grid.Column="3"
                        Content="CLR"
                        Style="{StaticResource TermButton}"
                        Padding="10,9"
                        VerticalAlignment="Center"
                        Click="BtnClear_Click"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 3  — STATUS BAR
        ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#030603">
            <Border.BorderBrush>
                <SolidColorBrush Color="#0F2A0F"/>
            </Border.BorderBrush>
            <Border.BorderThickness>0,1,0,0</Border.BorderThickness>
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel"
                           Text="CYBERSECURITY POE  //  system ready  //  awaiting input..."
                           FontSize="10" Foreground="{StaticResource GrayGreenBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Cybersecurity POE  •  Awareness Terminal  •  v2.0"
                           FontSize="10" Foreground="#0F2A0F"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
